# Copy to .env.local and fill in from Supabase: Project Settings -> API.
# Both values are safe for the public frontend (the anon key is meant to ship in the client).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Rules AI endpoint (api/rules-qa.ts) - SERVER-ONLY, never shipped to the browser ---
# Google Gemini API key. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
# Optional: enables per-IP rate limiting on the Rules AI endpoint.
# The service-role key is a SECRET - set it only as a server-side env var, never with a VITE_ prefix.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_URL=https://YOUR-PROJECT.supabase.co
